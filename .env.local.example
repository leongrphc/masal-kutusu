# Google Gemini API Key
# Get your API key from: https://aistudio.google.com/app/apikey
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Supabase Configuration
# Create a project at: https://supabase.com/dashboard
# Find these values in: Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# OPTIONAL: Service Role Key for server-side operations (bypasses RLS)
# Only needed for production. Development works with anon key.
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
APPLE_BUNDLE_ID=com.example.masalkutusu
APPLE_IAP_ENVIRONMENT=sandbox
APPLE_ROOT_CERTIFICATES_BASE64=base64_der_cert_1,base64_der_cert_2
APPLE_APP_ID=1234567890
GOOGLE_PLAY_PACKAGE_NAME=com.example.masalkutusu

# Node Environment
NODE_ENV=development
